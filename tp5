let nombreSecret = Math.floor(Math.random() * 10) + 1;
let tentative = 0;
let proposition;
alert("Devinez un nombre entre 1 et 10");
while (true) {
    proposition = Number(prompt("Quelle est votre proposition ?"));
    tentative++;
    if (proposition === nombreSecret) {
        alert("Bravo ! Vous avez trouvé en " + tentative + " tentatives");
        break;
    } 
    else if (proposition < nombreSecret) {
        alert("Le nombre secret est plus grand");
    } 
    else {
        alert("Le nombre secret est plus petit");
    }
}
