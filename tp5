<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Quiz Interactif</title>
</head>
<body>
    <h1>Quiz Interactif</h1>
    <button onclick="lancerQuiz()">Démarrer le Quiz</button>
    <script src="quiz.js"></script>
</body>
</html>
js:
let QUESTIONS = [
    ["Quelle est la capitale de la France ?", "Paris"],
    ["Quel langage rend les pages web interactives ?", "JavaScript"],
    ["Combien font 8 × 7 ?", "56"],
    ["Quelle est la capitale du Maroc ?", "Rabat"],
    ["Qui a inventé JavaScript ?", "Brendan Eich"]
];
function lancerQuiz() {
    let score = 0;
    for (let i = 0; i < QUESTIONS.length; i++) {
        let reponse = prompt(QUESTIONS[i][0]);
        if (reponse !== null && reponse.toLowerCase() === QUESTIONS[i][1].toLowerCase()) {
            alert("Réponse juste");
            score++;
        } else {
            alert("Réponse fausse");
        }
    }
    alert("Vous avez répondu correctement à " + score + " questions sur " + QUESTIONS.length);
}
